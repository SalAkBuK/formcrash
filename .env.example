# Browser-exposed dashboard setting. Do not put secrets in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_FORMCRASH_SERVER_URL=http://localhost:4100

DASHBOARD_PORT=3000
SERVER_HOST=127.0.0.1
SERVER_PORT=4100
SAMPLE_CHECKOUT_PORT=4200
FORMCRASH_LOG_LEVEL=info
# Comma-separated absolute dashboard origins. Wildcards are rejected.
FORMCRASH_DASHBOARD_ORIGINS=http://localhost:3000
FORMCRASH_DATABASE_PATH=./var/database/formcrash.db
FORMCRASH_ARTIFACT_ROOT=./var
FORMCRASH_BROWSER_HEADLESS=false
FORMCRASH_BROWSER_TIMEOUT_MS=10000
SAMPLE_CHECKOUT_BASE_URL=http://localhost:4200
