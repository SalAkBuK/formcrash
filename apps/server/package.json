{
  "name": "@formcrash/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "tsx src/persistence/migrate-cli.ts",
    "predev": "corepack pnpm --filter @formcrash/contracts build",
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "pretest": "corepack pnpm --filter @formcrash/contracts build",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "@formcrash/contracts": "workspace:*",
    "better-sqlite3": "12.11.1",
    "fastify": "5.10.0",
    "playwright": "1.61.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13"
  }
}
